{% comment %}
  Hero Banner Section - Optimized
  Homepage hero with gradient overlay and CTA
{% endcomment %}

<style>
  #hero-{{ section.id }} {
    position: relative;
    min-height: {{ section.settings.height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #2F2F2F;
  }

  #hero-{{ section.id }} .hero-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  #hero-{{ section.id }} .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(0, 206, 209, 0.7), rgba(147, 112, 219, 0.7));
    z-index: 2;
  }

  #hero-{{ section.id }} .hero-content {
    position: relative;
    z-index: 3;
    text-align: center;
    color: white;
    max-width: 800px;
    padding: 40px 20px;
  }

  #hero-{{ section.id }} .hero-heading {
    font-family: 'Poppins', sans-serif;
    font-weight: 700;
    font-size: clamp(36px, 5vw, 62px);
    margin: 0 0 16px 0;
    text-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  #hero-{{ section.id }} .hero-subheading {
    font-size: clamp(18px, 2vw, 24px);
    margin: 0 0 32px 0;
    opacity: 0.95;
  }

  #hero-{{ section.id }} .hero-cta {
    display: inline-block;
    padding: 16px 40px;
    background: linear-gradient(90deg, #00CED1, #9370DB);
    color: white;
    text-decoration: none;
    border-radius: 20px;
    font-weight: 700;
    font-family: 'Poppins', sans-serif;
    font-size: 18px;
    transition: transform 0.2s, box-shadow 0.2s;
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.3);
  }

  #hero-{{ section.id }} .hero-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.4);
  }

  @media (max-width: 768px) {
    #hero-{{ section.id }} {
      min-height: {{ section.settings.mobile_height }}px;
    }
  }
</style>

<section id="hero-{{ section.id }}" class="hero-banner">
  {% if section.settings.image %}
    <img
      src="{{ section.settings.image | img_url: '2000x' }}"
      srcset="{{ section.settings.image | img_url: '800x' }} 800w,
              {{ section.settings.image | img_url: '1200x' }} 1200w,
              {{ section.settings.image | img_url: '2000x' }} 2000w"
      sizes="100vw"
      alt="{{ section.settings.heading | escape }}"
      class="hero-image"
      loading="eager"
      fetchpriority="high"
    >
  {% endif %}

  <div class="hero-overlay"></div>

  <div class="hero-content">
    {% if section.settings.heading %}
      <h1 class="hero-heading">{{ section.settings.heading }}</h1>
    {% endif %}

    {% if section.settings.subheading %}
      <p class="hero-subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    {% if section.settings.cta_text and section.settings.cta_link %}
      <a href="{{ section.settings.cta_link }}" class="hero-cta">
        {{ section.settings.cta_text }}
      </a>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "class": "hero-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Discover Koh Samui's Best Tours"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium Experiences from Verified Local Operators"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button Text",
      "default": "Explore Tours"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "height",
      "min": 400,
      "max": 800,
      "step": 50,
      "unit": "px",
      "label": "Desktop Height",
      "default": 600
    },
    {
      "type": "range",
      "id": "mobile_height",
      "min": 300,
      "max": 600,
      "step": 50,
      "unit": "px",
      "label": "Mobile Height",
      "default": 400
    }
  ],
  "presets": [
    {
      "name": "Hero Banner",
      "category": "Banner"
    }
  ]
}
{% endschema %}
