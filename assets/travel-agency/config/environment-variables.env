# N8N Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http

# Shopify Configuration
SHOPIFY_SHOP_URL=your-shop.myshopify.com
SHOPIFY_ACCESS_TOKEN=your_shopify_access_token
SHOPIFY_API_VERSION=2024-01
SHOPIFY_WEBHOOK_SECRET=your_webhook_secret

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token
LINE_CHANNEL_SECRET=your_line_channel_secret

# Zoho CRM
ZOHO_CLIENT_ID=your_zoho_client_id
ZOHO_CLIENT_SECRET=your_zoho_client_secret
ZOHO_REFRESH_TOKEN=your_zoho_refresh_token
ZOHO_API_DOMAIN=https://www.zohoapis.com

# Zoho Mail
ZOHO_MAIL_USER=your_email@yourdomain.com
ZOHO_MAIL_PASSWORD=your_zoho_mail_password
ZOHO_SMTP_HOST=smtp.zoho.com
ZOHO_SMTP_PORT=587

# Google Sheets
GOOGLE_SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_SHEETS_PRIVATE_KEY=your_private_key
GOOGLE_SPREADSHEET_ID=your_spreadsheet_id

# Google Drive
GOOGLE_DRIVE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_DRIVE_PRIVATE_KEY=your_private_key
GOOGLE_DRIVE_FOLDER_ID=your_folder_id

# QuickBooks
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret
QUICKBOOKS_REALM_ID=your_realm_id
QUICKBOOKS_REFRESH_TOKEN=your_refresh_token
QUICKBOOKS_ENVIRONMENT=sandbox

# OpenAI for AI Chatbot
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_ORGANIZATION=your_org_id

# Business Configuration
BUSINESS_NAME=Your Travel Agency Name
BUSINESS_EMAIL=info@yourtravelagency.com
BUSINESS_PHONE=+66812345678
BUSINESS_WEBSITE=https://yourtravelagency.com
SUPPORT_EMAIL=support@yourtravelagency.com

# Timezone
TIMEZONE=Asia/Bangkok

# Payment Methods Configuration

# Thai Bank Transfer
THAI_BANK_NAME=Bangkok Bank
THAI_BANK_ACCOUNT_NAME=Your Travel Agency Ltd
THAI_BANK_ACCOUNT_NUMBER=123-456-7890
THAI_BANK_BRANCH=Central Bangkok Branch

# PromptPay QR Code
PROMPTPAY_ID=0812345678
# This is your Thai mobile number or Tax ID for PromptPay

# PayPal
PAYPAL_USERNAME=yourtravelagency
# PayPal.me username (paypal.com/paypalme/yourtravelagency)

# Stripe Payment Links
STRIPE_PAYMENT_LINK_BASE=https://buy.stripe.com/test_xxxxx
# Get this from Stripe Dashboard → Payment Links

# Wise (TransferWise)
WISE_EMAIL=payments@yourtravelagency.com
# Email associated with your Wise account

# Revolut
REVOLUT_USERNAME=yourtravelagency
# Your Revolut.me username

# Google Maps API (for location selection)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# WhatsApp Business API (via Twilio)
TWILIO_WHATSAPP_NUMBER=whatsapp:+66812345678
# Your Twilio WhatsApp number

# Report Schedule (Cron expressions)
MORNING_REPORT_CRON=0 6 * * *
EVENING_REPORT_CRON=0 20 * * *
VOUCHER_DELIVERY_CRON=0 10 * * *
PRE_TOUR_REMINDER_CRON=*/15 * * * *
