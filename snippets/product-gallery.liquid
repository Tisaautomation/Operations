{% comment %}
  Product Image Gallery with Zoom
  Optimized for mobile performance
  Lazy loading applied to images beyond first 3
{% endcomment %}

<div class="product-gallery" data-component="product-gallery">
  <div class="gallery-main">
    {% if product.featured_image %}
      <div class="gallery-main-image">
        <img
          src="{{ product.featured_image | img_url: '800x800' }}"
          srcset="{{ product.featured_image | img_url: '400x400' }} 400w,
                  {{ product.featured_image | img_url: '800x800' }} 800w,
                  {{ product.featured_image | img_url: '1200x1200' }} 1200w"
          sizes="(max-width: 768px) 100vw, 50vw"
          alt="{{ product.featured_image.alt | escape }}"
          width="800"
          height="800"
          class="gallery-image active"
          data-zoom-src="{{ product.featured_image | img_url: '1200x1200' }}"
        >
        <button class="btn-zoom" aria-label="Zoom image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <path d="m21 21-4.35-4.35"></path>
            <line x1="11" y1="8" x2="11" y2="14"></line>
            <line x1="8" y1="11" x2="14" y2="11"></line>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>

  {% if product.images.size > 1 %}
    <div class="gallery-thumbnails">
      {% for image in product.images %}
        <button
          class="thumbnail{% if forloop.first %} active{% endif %}"
          data-image-index="{{ forloop.index0 }}"
          aria-label="View image {{ forloop.index }}"
        >
          <img
            src="{{ image | img_url: '150x150' }}"
            alt="{{ image.alt | escape }}"
            width="150"
            height="150"
            {% if forloop.index > 3 %}loading="lazy"{% endif %}
          >
        </button>
      {% endfor %}
    </div>
  {% endif %}

  {%- comment -%} Zoom Modal {%- endcomment -%}
  <div id="zoom-modal" class="zoom-modal" hidden>
    <button class="zoom-close" aria-label="Close zoom">×</button>
    <div class="zoom-container">
      <img src="" alt="" class="zoom-image">
    </div>
  </div>
</div>

<script>
  // Gallery interaction handled in assets/product-page.js
</script>
