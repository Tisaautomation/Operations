# ============================================================================
# Tour in Koh Samui — Environment Variables Template
# ============================================================================
# Copy this file to `.env` (which is gitignored) and fill in the values.
# NEVER commit the real `.env` file.
#
# These are read by local tooling (Shopify CLI, scripts, etc.). Shopify theme
# settings themselves (google_maps_api_key, mapbox_access_token) live in the
# live store and are set via admin — see CLAUDE.md §10.
# ============================================================================

# ----- Shopify Admin API (for theme CLI + Admin API scripts) -----
# Get from: Shopify admin → Apps → Develop apps → Create app → Configure Admin API scopes
# Required for: `shopify theme dev/push/pull` and any automated Admin API calls.
SHOPIFY_STORE_DOMAIN=tourinkohsamui.myshopify.com
SHOPIFY_ADMIN_API_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# ----- Shopify Storefront API (for headless / custom frontend calls) -----
# Get from: Shopify admin → Apps → Develop apps → Configure Storefront API scopes
SHOPIFY_STOREFRONT_API_TOKEN=

# ----- Shopify Theme CLI auth -----
# Usually managed by `shopify login --store tourinkohsamui.myshopify.com`
# No token needed here if you use the interactive CLI login.

# ----- Google Maps (local testing only; production key lives in theme settings) -----
GOOGLE_MAPS_API_KEY=

# ----- Mapbox (local testing only; production token lives in theme settings) -----
MAPBOX_ACCESS_TOKEN=

# ----- GitHub (only needed for local gh CLI; Claude Code uses its own MCP) -----
# GITHUB_TOKEN=

# ----- Supabase (if used for backend features) -----
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ----- Vercel (if used for preview deployments) -----
# VERCEL_TOKEN=
